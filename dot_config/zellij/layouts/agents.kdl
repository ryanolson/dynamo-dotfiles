// Agent infrastructure overview layout
// Start with: zellij --session agents --layout agents
// Or use the fish function: agents

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="overview" focus=true {
        pane split_direction="vertical" {
            pane name="status" size="70%" {
                command "watch"
                args "-n" "5" "-c" "agent-status"
            }
            pane name="git-log" size="30%" {
                command "watch"
                args "-n" "10" "-c" "git log --oneline --graph --all -25 --color=always"
            }
        }
    }

    tab name="shell" {
        pane
    }
}
