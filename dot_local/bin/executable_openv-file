#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: openv-file <env-file> <command...>" >&2
    exit 1
}

[[ $# -ge 2 ]] || usage

ENV_FILE="$1"
shift

if ! command -v op >/dev/null 2>&1; then
    echo "openv-file: 1Password CLI (op) is not installed" >&2
    exit 1
fi

if [[ ! -f "$ENV_FILE" ]]; then
    echo "openv-file: env file not found at $ENV_FILE" >&2
    exit 1
fi

exec op run --env-file "$ENV_FILE" -- "$@"
