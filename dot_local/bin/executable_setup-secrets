#!/usr/bin/env bash
# Setup and verify 1Password-backed command wrappers and git signing.
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

ENV_FILE="${DYNAMO_OP_ENV_FILE:-$HOME/.config/dynamo/dev.env.op}"
VAULT="Development"
ITEMS=("Anthropic API" "HuggingFace" "GitHub Token" "NGC")

log() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}  OK${NC}  $1"; }
warn() { echo -e "${YELLOW}WARN${NC}  $1"; }
fail() { echo -e "${RED}FAIL${NC}  $1"; }

usage() {
    cat <<'EOF'
Usage:
  setup-secrets
  setup-secrets remote <host>
EOF
}

check_local() {
    echo ""
    echo "Dynamo Secrets Setup"
    echo "===================="
    echo ""

    log "Checking helper commands..."
    for cmd in op openv dev-remote git-signing-status; do
        if command -v "$cmd" >/dev/null 2>&1; then
            success "$cmd is installed"
        else
            fail "$cmd is missing"
            exit 1
        fi
    done

    log "Checking 1Password sign-in..."
    if op whoami >/dev/null 2>&1; then
        success "Signed in to 1Password"
    else
        fail "Not signed in to 1Password"
        echo "  Run: op account add   (first time)"
        echo "  Run: op signin        (subsequent times)"
        exit 1
    fi

    log "Checking env reference file..."
    if [[ -f "$ENV_FILE" ]]; then
        success "Found $ENV_FILE"
    else
        fail "Missing $ENV_FILE"
        echo "  Run: chezmoi apply"
        exit 1
    fi

    if grep -Eq '^[A-Z0-9_]+=op://' "$ENV_FILE"; then
        success "Env file contains 1Password secret references"
    else
        warn "Env file does not contain any secret references"
    fi

    log "Checking vault items..."
    all_found=true
    for item in "${ITEMS[@]}"; do
        if op item get "$item" --vault "$VAULT" >/dev/null 2>&1; then
            success "Found '$item' in vault '$VAULT'"
        else
            fail "Missing '$item' in vault '$VAULT'"
            all_found=false
        fi
    done
    if [[ "$all_found" = false ]]; then
        echo ""
        warn "Some expected items are missing from 1Password."
    fi

    log "Checking commit signing configuration..."
    signing_key="$(git config --global user.signingkey 2>/dev/null || true)"
    if [[ -n "$signing_key" ]]; then
        success "user.signingkey is set"
    else
        warn "user.signingkey is not set — commit signing is disabled"
        echo "  Add data.onepassword.signing_public_key to ~/.config/chezmoi/chezmoi.yaml and run: chezmoi apply"
    fi

    if [[ -f "$HOME/.ssh/allowed_signers" ]]; then
        success "~/.ssh/allowed_signers exists"
    else
        warn "~/.ssh/allowed_signers is missing — signature verification won't work"
        echo "  Run: chezmoi apply"
    fi

    if [[ "$OSTYPE" == darwin* ]]; then
        if [[ -x "/Applications/1Password.app/Contents/MacOS/op-ssh-sign" ]]; then
            success "op-ssh-sign found (macOS)"
        else
            warn "op-ssh-sign not found — install 1Password desktop app"
        fi
    else
        gpg_ssh_prog="$(git config --global gpg.ssh.program 2>/dev/null || true)"
        if [[ -z "$gpg_ssh_prog" ]]; then
            success "gpg.ssh.program is unset (will use ssh-keygen — correct for Linux)"
        else
            warn "gpg.ssh.program is set to '$gpg_ssh_prog' — should be unset on Linux"
        fi
    fi

    if git-signing-status >/dev/null 2>&1; then
        success "$(git-signing-status)"
    else
        warn "$(git-signing-status 2>/dev/null || true)"
    fi

    if [[ -n "$signing_key" ]]; then
        log "Testing commit signature..."
        tmpdir="$(mktemp -d)"
        if (cd "$tmpdir" && git init -q && git commit --allow-empty -m "signing test" -q 2>/dev/null); then
            success "Test commit signed successfully"
        else
            warn "Test commit signing failed — check the active signing transport"
        fi
        rm -rf "$tmpdir"
    fi

    echo ""
    log "To upload your signing key to GitHub (for Verified badges):"
    echo "  gh ssh-key add ~/.ssh/allowed_signers --type signing --title 'chezmoi-signing'"
    echo "  Or: GitHub.com > Settings > SSH and GPG keys > New SSH key > Type: Signing Key"

    echo ""
    echo "Next Steps"
    echo "----------"
    echo ""
    echo "1. Enable 1Password in chezmoi config:"
    echo "   data:"
    echo "     onepassword:"
    echo "       enabled: true"
    echo "       ssh_agent: true"
    echo "       signing_public_key: \"ssh-ed25519 ...\""
    echo ""
    echo "2. Apply configuration:"
    echo "   chezmoi apply"
    echo ""
    echo "3. Run commands with on-demand secrets:"
    echo "   openv env | rg 'ANTHROPIC_API_KEY|HF_TOKEN|GITHUB_TOKEN|NGC_API_KEY'"
    echo ""
    echo "4. Start or refresh a remote dev session:"
    echo "   dev-remote <host>"
    echo "   dev-remote refresh <host> <session>"
    echo ""
    echo "5. One-time auth steps:"
    echo "   claude login          # Claude Code OAuth (opens browser)"
    echo "   gh auth login -p ssh  # GitHub CLI via SSH agent"
    echo ""
}

check_remote() {
    local host="${1:-}"
    [[ -n "$host" ]] || {
        usage >&2
        exit 1
    }

    echo ""
    echo "Dynamo Remote Secrets Setup"
    echo "==========================="
    echo ""

    log "Checking SSH connectivity to $host..."
    if ssh -A -o BatchMode=yes "$host" true >/dev/null 2>&1; then
        success "SSH connectivity works"
    else
        fail "Could not connect to $host with ssh -A"
        exit 1
    fi

    log "Checking remote helper installation..."
    if ssh -A "$host" 'command -v zellij >/dev/null 2>&1 && test -x "$HOME/.local/bin/dynamo-remote-session"' >/dev/null 2>&1; then
        success "Remote zellij and dynamo-remote-session are installed"
    else
        fail "Remote helper is missing — run chezmoi apply on $host"
        exit 1
    fi

    log "Checking forwarded SSH agent on remote..."
    if ssh -A "$host" 'test -S "$HOME/.ssh/auth_sock"' >/dev/null 2>&1; then
        success "Remote stable SSH_AUTH_SOCK is available"
    else
        warn "Remote stable SSH_AUTH_SOCK is missing — reconnect with ssh -A or dev-remote"
    fi

    log "Checking remote signing transport..."
    remote_status="$(ssh -A "$host" '$HOME/.local/bin/git-signing-status' 2>/dev/null || true)"
    if [[ -n "$remote_status" ]]; then
        echo "  $remote_status"
    else
        warn "git-signing-status is unavailable on the remote host"
    fi

    log "Testing remote commit signing..."
    if ssh -A "$host" "bash -lc 'export SSH_AUTH_SOCK=\"\$HOME/.ssh/auth_sock\"; tmpdir=\$(mktemp -d); cd \"\$tmpdir\"; git init -q; git commit --allow-empty -m setup-secrets-test -q >/dev/null 2>&1; status=\$?; rm -rf \"\$tmpdir\"; exit \$status'" >/dev/null 2>&1; then
        success "Remote test commit signed successfully"
    else
        warn "Remote signing test failed — reconnect with ssh -A or dev-remote and retry"
    fi

    log "Priming a remote zellij session..."
    if ssh -A "$host" '$HOME/.local/bin/dynamo-remote-session prime --session setup-secrets-check' </dev/null >/dev/null 2>&1; then
        success "Remote zellij session primed"
    else
        warn "Could not prime the remote zellij session"
    fi

    echo ""
    echo "Remote Workflow"
    echo "---------------"
    echo ""
    echo "Use standard OpenSSH over the tailnet for sessions that need git signing:"
    echo "  dev-remote $host"
    echo "  dev-remote refresh $host main"
    echo ""
}

case "${1:-}" in
    "")
        check_local
        ;;
    remote)
        check_remote "${2:-}"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        usage >&2
        exit 1
        ;;
esac
