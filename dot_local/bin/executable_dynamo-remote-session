#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/.cargo/bin:$HOME/.local/share/mise/shims:$HOME/.local/bin:$PATH"

usage() {
    cat >&2 <<'EOF'
Usage:
  dynamo-remote-session prime [--session NAME] [--refresh]
  dynamo-remote-session attach [--session NAME]
EOF
    exit 1
}

session="main"
command_name="${1:-}"
[[ -n "$command_name" ]] || usage
shift || true
refresh=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --session)
            session="${2:?missing session name}"
            shift 2
            ;;
        --refresh)
            refresh=1
            shift
            ;;
        *)
            usage
            ;;
    esac
done

have_session() {
    zellij list-sessions -s 2>/dev/null | grep -Fxq "$session"
}

refresh_auth_sock() {
    local stable_sock="$HOME/.ssh/auth_sock"

    mkdir -p "$HOME/.ssh"

    if [[ -n "${SSH_AUTH_SOCK:-}" ]] && [[ "$SSH_AUTH_SOCK" != "$stable_sock" ]]; then
        ln -sf "$SSH_AUTH_SOCK" "$stable_sock"
    fi

    if [[ -S "$stable_sock" ]]; then
        export SSH_AUTH_SOCK="$stable_sock"
    fi
}

refresh_term() {
    if [[ -z "${TERM:-}" ]]; then
        export TERM="xterm-256color"
    fi
}

load_payload() {
    local line name encoded decoded
    while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        name="${line%%=*}"
        encoded="${line#*=}"
        [[ "$name" =~ ^[A-Z0-9_]+$ ]] || continue
        decoded="$(printf '%s' "$encoded" | base64 -d)"
        export "$name=$decoded"
    done
}

case "$command_name" in
    prime)
        load_payload
        refresh_auth_sock
        refresh_term
        if [[ "$refresh" -eq 1 ]] && have_session; then
            zellij kill-session "$session" >/dev/null 2>&1 || true
        fi
        if ! have_session; then
            zellij attach -b -c "$session" >/dev/null 2>&1 || {
                echo "Failed to create zellij session '$session'" >&2
                exit 1
            }
        fi
        ;;
    attach)
        refresh_auth_sock
        refresh_term
        exec zellij attach -c "$session"
        ;;
    *)
        usage
        ;;
esac
