#!/usr/bin/env bash

# Exit immediately if a command exits with a non-zero status
set -e

if [ -z "$1" ]; then
    echo "Error: Please provide a commit message."
    echo "Usage: gsd-sync 'your commit message'"
    exit 1
fi

COMMIT_MSG="$1"

# 1. Commit to the main project
echo "📦 Committing to main project..."
git commit -s -m "$COMMIT_MSG"

# 2. Check if the shadow .planning repo exists
if [ -d ".planning/.git" ]; then
    echo "🕵️‍♂️ Committing to shadow planning repo..."
    # Execute in a subshell so we don't mess up the working directory
    (
        cd .planning
        git add -A
        git commit -s -m "$COMMIT_MSG"
        # Uncomment the next line if you want it to auto-push your private plans
        # git push origin main
    )
fi

echo "✅ Both spaces synced!"
