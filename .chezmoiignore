# Files to ignore when applying dotfiles
# These files won't be managed by chezmoi

README.md
LICENSE
.git/

# Development files
.chezmoi*
.tool-versions
.mise.toml

# OS-specific files
{{- if ne .chezmoi.os "darwin" }}
# Ignore macOS-specific files on non-macOS systems
.DS_Store
.macos
{{- end }}

{{- if ne .chezmoi.os "linux" }}
# Ignore Linux-specific files on non-Linux systems  
.linux
{{- end }}

# Personal files that shouldn't be managed
.ssh/id_*
.ssh/known_hosts
.aws/credentials
.docker/config.json

# Local development files
node_modules/
.env
.env.local
*.log

# IDE-specific files (user preference)
.vscode/
.idea/
*.sublime-*

# Temporary files
*.tmp
*.swp
*.swo
*~
.#*

# OS cache files
Thumbs.db
Desktop.ini

# Agent infrastructure (only for remote-dev machines)
{{- if ne .machine_type "remote-dev" }}
dot_local/bin/executable_wt.tmpl
dot_local/bin/executable_agent-spawn.tmpl
dot_local/bin/executable_agent-status.tmpl
dot_local/bin/executable_generate-dashboard.tmpl
dot_local/bin/executable_osc8-link
dot_config/zellij/layouts/agents.kdl
dot_config/systemd/
dot_config/fish/conf.d/agent-aliases.fish
dot_config/fish/conf.d/ssh-auth-sock.fish.tmpl
{{- end }}

# systemd only on Linux
{{- if ne .chezmoi.os "linux" }}
dot_config/systemd/
{{- end }}

# .claude hooks — primary only (GSD infra tightly coupled to primary's environment)
{{- if ne .user_role "primary" }}
dot_claude/hooks/
{{- end }}

# Shared cache symlinks — only for primary/secondary users with /opt/shared-cache present
{{- if or (eq .user_role "standalone") (not (stat "/opt/shared-cache")) }}
dot_cache/symlink_huggingface.tmpl
dot_cache/symlink_llama.cpp.tmpl
{{- end }}
